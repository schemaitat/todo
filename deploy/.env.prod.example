# Remote server production environment
# Copy to .env on the server, fill in all values, chmod 600 .env

# --- Domain ------------------------------------------------------------------
DOMAIN=yourdomain.com
API_SUBDOMAIN=todo
N8N_SUBDOMAIN=n8n

# --- Postgres ----------------------------------------------------------------
POSTGRES_USER=todo
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=todo

# --- API ---------------------------------------------------------------------
BOOTSTRAP_USER_EMAIL=you@example.com
BOOTSTRAP_API_KEY=todo_changeme_strong_key

# --- TUI client (used locally, not on server) --------------------------------
TODO_API_URL=https://todo.yourdomain.com
TODO_API_KEY=todo_changeme_strong_key
TODO_CONTEXT=inbox

# --- n8n ---------------------------------------------------------------------
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_strong_password
N8N_TIMEZONE=Europe/Berlin
TODO_SNAPSHOT_EMAIL=you@example.com
N8N_GOOGLE_CLIENT_ID=
N8N_GOOGLE_CLIENT_SECRET=
